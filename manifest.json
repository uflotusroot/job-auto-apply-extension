{
  "manifest_version": 3,
  "name": "自动投递助手",
  "version": "3.0.0",
  "description": "根据技能匹配自动投递简历到各大招聘平台，支持Boss直聘、智联、51job、应届生等",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://*.zhipin.com/*",
    "*://*.zhaopin.com/*",
    "*://*.jobonline.cn/*",
    "*://*.51job.com/*",
    "*://*.yingjiesheng.com/*",
    "*://*.jobs.51job.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.zhipin.com/*",
        "*://*.zhaopin.com/*",
        "*://*.jobonline.cn/*",
        "*://*.51job.com/*",
        "*://*.yingjiesheng.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
